# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token

# Notion Integration (Dashboard)
NOTION_TOKEN=your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id

# Notion 知識庫 (Phase 6)
NOTION_KNOWLEDGE_TOKEN=your-notion-knowledge-integration-token
NOTION_RESTAURANT_DB=your-restaurant-database-id
NOTION_TICKET_DB=your-ticket-database-id
NOTION_REPLIES_DB=your-replies-database-id
NOTION_HOTEL_DB=your-hotel-database-id
NOTION_CAFE_DB=your-cafe-database-id
NOTION_ATTRACTION_DB=your-attraction-database-id

# API Security
INTERNAL_API_KEY=your-secure-api-key-here
REVALIDATE_SECRET=your-revalidate-secret-token
# ⚠️ Sanity Webhook 設定：
#    URL: https://chiangway-travel.com/api/revalidate
#    HTTP Header: Authorization = Bearer {REVALIDATE_SECRET}
#    (不要用 query param ?secret=xxx，已移除支援)

# Dashboard Access (comma-separated email whitelist)
DASHBOARD_ALLOWED_EMAILS=email1@example.com,email2@example.com

# ─── LINE OA Agent (Task 2+) ────────────────────────────────────────────────

# LINE
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_PARTNER_GROUP_ID=
# Bot's own LINE userId — enables structured @-mention detection in the partner
# group. Optional: leave empty to fall back to text alias/wake-word detection.
LINE_BOT_USER_ID=
LINE_ROUTE_MODE=discord_smoke

# DC / Discord operator bridge
AI_AGENT_INTERNAL_SECRET=
DISCORD_PRIVATE_CHANNEL_ID=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# Models
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_AGENT_DEFAULT_MODEL=
AI_AGENT_RESEARCH_MODEL=
AI_AGENT_VISION_MODEL=
# PartnerGroupResponder mode (optional)
#   - 預設 stub：合作群組 responder 走固定回覆，不呼叫真模型。
#   - 設 anthropic 才會啟用 PartnerGroupResponder 真模型（需同時有 ANTHROPIC_API_KEY）；
#     即使 key 存在，沒顯式設 anthropic 也不會自動啟用。
#   - 僅建議先設 Vercel Preview 驗證，確認無誤前不要先設 Production。
AI_AGENT_PARTNER_RESPONDER_MODE=stub

# External tool / billing gate (M3-0 — policy only, no provider wired yet)
#   - 高成本外部工具預設一律 OFF；只有明確設為 "true" 才開（"1"/"yes" 不算）。
#   - 客人平面 line_oa 永遠不可用外部工具，與這些旗標無關（雙保險）。
#   - 合作群組要 allow 還需：botDirected + 使用者明確要求查網路/即時資料 + cost cap 未超。
#   - 僅建議先設 Vercel Preview 驗證；確認前不要先開 Production。
AI_AGENT_WEB_SEARCH_ENABLED=false
AI_AGENT_OCR_ENABLED=false
AI_AGENT_NOTION_RAG_ENABLED=false
# 外部工具花費上限（USD）。預設 0 = 沒預算，即使工具開了也擋；設正值才有額度。
AI_AGENT_TOOL_COST_CAP_USD=0

# Notion 2026 team-collaboration READ adapter (Phase B — read-only)
# Reuses NOTION_TOKEN defined above. The read path accepts ONLY this database
# id (any other id is refused). If a separate integration token is ever needed,
# introduce NOTION_TEAM_2026_TOKEN then. No write path is wired in Phase B.
NOTION_TEAM_2026_DATABASE_ID=

# Storage
AGENT_KV_URL=
AGENT_KV_TOKEN=
AGENT_RETENTION_DAYS=90
